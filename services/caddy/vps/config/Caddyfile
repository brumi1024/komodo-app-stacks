##################
# Global options #
##################
{
    dynamic_dns {
      provider cloudflare {$CF_API_TOKEN}
      domains {
        {$DOMAIN} @ * *.seq *.kalasz
      }
      versions ipv4
    }

    dynamic_dns {
      provider cloudflare {$CF_API_TOKEN}
      domains {
        {$DOMAIN} @ * *.kalasz
      }
      versions ipv6
      ip_source simple_http https://ipv6.icanhazip.com
      ip_source simple_http https://api6.ipify.org
    }

    # The admin API is reachable only on Docker networks because it is not
    # published by Compose. Homepage uses it for the Caddy widget.
    admin 0.0.0.0:2019
}


############
# Snippets #
############
(cloudflare) {
  tls {
    dns cloudflare {$CF_API_TOKEN}
    resolvers 1.1.1.1 1.0.0.1
  }

  encode zstd gzip
}

(log_common) {
  log {
    output file /var/log/caddy/caddy_access.log
  }
}

(authenticate) {
      # always forward outpost path to actual outpost
      reverse_proxy /outpost.goauthentik.io/* http://authentik-server:9000

      # forward authentication to outpost
      forward_auth http://authentik-server:9000 {
          uri /outpost.goauthentik.io/auth/caddy

          # capitalization of the headers is important, otherwise they will be empty
          copy_headers X-Authentik-Username X-Authentik-Groups X-Authentik-Entitlements X-Authentik-Email X-Authentik-Name X-Authentik-Uid X-Authentik-Jwt X-Authentik-Meta-Jwks X-Authentik-Meta-Outpost X-Authentik-Meta-Provider X-Authentik-Meta-App X-Authentik-Meta-Version X-Forwarded-Role authorization

          # optional, in this config trust all private ranges, should probably be set to the outposts IP
          trusted_proxies private_ranges
      }
}

# Local network authentication bypass
(authenticate_with_tailscale_bypass) {
      @tailscale_network {
            remote_ip 100.64.0.0/10
        }
      
      # Skip authentication for local network requests
      handle @tailscale_network {
          # Just pass through to the backend without authentication
      }
      
      # Apply authentication for non-local requests
      handle {
          import authenticate
      }
}

##########################
# VPS Hosted Services    #
##########################

komodo.{$DOMAIN} {
    import cloudflare
    import log_common
    reverse_proxy komodo-core:9120 docker.{$TAILNET}:9120 {
        lb_policy first
        health_uri /
        health_interval 10s
        health_timeout 3s
        fail_duration 30s
        lb_try_duration 5s
    }
}

beszel.{$DOMAIN} {
    import cloudflare
    import log_common
    reverse_proxy beszel:8090
}

uptime.{$DOMAIN} {
    import cloudflare
    import log_common
    import authenticate_with_tailscale_bypass
    reverse_proxy uptime-kuma:3001
}

ntfy.{$DOMAIN} {
    import cloudflare
    import log_common
    reverse_proxy ntfy:80
}

auth.{$DOMAIN} {
    import cloudflare
    reverse_proxy authentik-server:9000
}

dash.{$DOMAIN} {
    import authenticate_with_tailscale_bypass
    import cloudflare
    reverse_proxy homepage:3000
}

actual.{$DOMAIN} {
    import cloudflare
    reverse_proxy docker.{$TAILNET}:{$PORT_ACTUAL_HTTP}
}

