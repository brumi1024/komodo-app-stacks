#####################################################
# Sequoia Site Services - Required by IPv4 clients  #
#####################################################

# Home Assistant
homeassistant.seq.{$DOMAIN} {
    import cloudflare
    reverse_proxy {
        dynamic a seq-origin-v6.{$DOMAIN} 443 {
            versions ipv6
        }
        header_up Host homeassistant.seq.{$DOMAIN}
        transport http {
            tls
            tls_server_name homeassistant.seq.{$DOMAIN}
        }
    }
}

